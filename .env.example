# ============================================
# QuickBooks Payments Template - Environment Variables
# ============================================
# Copy this to .env.local for local dev
# In Vercel, add these in Settings > Environment Variables

# ---- Vercel Postgres (auto-set when you add Postgres storage) ----
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# ---- App URL ----
NEXT_PUBLIC_URL=http://localhost:3000

# ---- QuickBooks API Credentials ----
QB_CLIENT_ID=your_client_id_here
QB_CLIENT_SECRET=your_client_secret_here

# ---- OAuth Redirect URI (MUST match Intuit Developer Settings) ----
QB_REDIRECT_URI=http://localhost:3000/api/quickbooks/callback

# ---- QuickBooks Environment: sandbox or production ----
QB_ENVIRONMENT=sandbox

# ---- Auth Secret (generate: openssl rand -base64 32) ----
JWT_SECRET=change-this-to-a-random-secret-string
